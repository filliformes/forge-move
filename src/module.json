{
    "id": "forge",
    "name": "Forge",
    "abbrev": "FORGE",
    "version": "0.3.0",
    "api_version": 2,
    "description": "8-voice FM/subtractive hybrid drum synthesiser with Kit A↔B morph across 16 pads — 5 voice algorithms (Drum/Snare/Cymbal/Hat/Wild), per-voice resonator + body wavefolder, dual filter with Base-Width pre-stage, three concurrent FX buses",
    "author": "Vincent Fillion",
    "license": "MIT",
    "dsp": "dsp.so",
    "component_type": "sound_generator",
    "raw_midi": true,

    "defaults": {
        "kit": 0,
        "morph": 0.0,
        "all_decay": 1.0,
        "v1_lvl": 0.9, "v2_lvl": 0.85, "v3_lvl": 0.8, "v4_lvl": 0.75,
        "v5_lvl": 0.8, "v6_lvl": 0.6, "v7_lvl": 0.55, "v8_lvl": 0.6,
        "comp": 0.0, "drive": 0.0, "bit": 0.0, "rate": 0.0,
        "eq_lo": 0.0, "eq_mid": 0.0, "eq_hi": 0.0,
        "master": 0.85,
        "rev_mix": 0.0, "rev_decay": 0.5, "rev_size": 0.5,
        "dly_mix": 0.0, "dly_rate": 0.3, "dly_fdbk": 0.3, "dly_tone": 0.5,
        "cho_mix": 0.0
    },

    "capabilities": {
        "audio_out": true,
        "midi_in": true,
        "chainable": true,
        "component_type": "sound_generator",

