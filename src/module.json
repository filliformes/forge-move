                               "copy_a_b", "copy_b_a", "swap_ab", "rnd_b_from_a",
                               "morph_src", "morph_curve"]
                },
                "Voice": {
                    "name": "Voice",
                    "knobs": ["cv_m1", "cv_m2", "cv_m3", "cv_m4", "cv_m5", "cv_m6", "cv_m7", "cv_m8"],
                    "params": [
                        "cv_vpreset",
                        {"level": "Osc",    "label": "Osc"},
                        {"level": "Filter", "label": "Filter"},
                        {"level": "Env",    "label": "Env"},
                        {"level": "Mod",    "label": "Mod"},
                        {"level": "Setup",  "label": "Setup"},
                        "cv_m1", "cv_m2", "cv_m3", "cv_m4", "cv_m5", "cv_m6", "cv_m7", "cv_m8"
                    ]
                },
