                    "name": "General",
                    "knobs": ["comp", "drive", "bit", "rate", "eq_lo", "eq_mid", "eq_hi", "master"],
                    "params": ["comp", "drive", "bit", "rate", "eq_lo", "eq_mid", "eq_hi", "master",
                               "drive_type", "lo_freq", "mid_freq", "hi_freq", "q_lo", "q_mid", "q_hi",
                               "limiter", "master_tune", "midi_ch"]
                }
            }
        },

