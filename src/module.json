                    "knobs": ["rev_mix", "rev_decay", "rev_size", "dly_mix", "dly_rate", "dly_fdbk", "dly_tone", "cho_mix"],
                    "params": ["rev_mix", "rev_decay", "rev_size", "dly_mix", "dly_rate", "dly_fdbk", "dly_tone", "cho_mix",
