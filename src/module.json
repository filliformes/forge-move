                               "cv_v_e1_lvl", "cv_v_e1_t", "cv_v_e2_amt",
                               "cv_fie1_amt", "cv_fie1_dec", "cv_fie2_amt", "cv_fie2_dec"]
                },
                "Mod": {
                    "name": "Mod",
                    "knobs": ["cv_lfo_w", "cv_lfo_r", "cv_lfo_s", "cv_lfo_d", "cv_xlfo_src", "cv_trig_rst", "cv_mod_dest", "cv_mod_dpth"],
