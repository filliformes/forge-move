                               "cv_lfo_w2", "cv_lfo_morph"]
                },
                "Setup": {
                    "name": "Setup",
                    "knobs": ["cv_algo", "cv_choke", "cv_bus", "cv_lvl", "cv_tune", "cv_poly", "cv_glide", "cv_init"],
                    "params": ["cv_algo", "cv_choke", "cv_bus", "cv_lvl", "cv_tune", "cv_poly", "cv_glide", "cv_init",
                               "cv_pan", "cv_mute", "cv_fx1", "cv_fx2", "cv_vsens", "cv_note"]
                },
                "Mix": {
                    "name": "Mix",
                    "knobs": ["v1_lvl", "v2_lvl", "v3_lvl", "v4_lvl", "v5_lvl", "v6_lvl", "v7_lvl", "v8_lvl"],
