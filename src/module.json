                        {"level": "Perf",    "label": "Perf"},
                        {"level": "Voice",   "label": "Voice"},
                        {"level": "Mix",     "label": "Mix"},
                        {"level": "FX",      "label": "FX"},
                        {"level": "General", "label": "General"}
                    ]
                },
                "Perf": {
                    "name": "Perf",
                    "knobs": ["all_punch", "all_bright", "all_decay", "all_drive", "all_snap", "all_bend", "all_tune", "all_fx"],
                    "params": ["all_punch", "all_bright", "all_decay", "all_drive", "all_snap", "all_bend", "all_tune", "all_fx"]
                },
                "Patch": {
