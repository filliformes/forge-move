                               "v1_pan", "v2_pan", "v3_pan", "v4_pan", "v5_pan", "v6_pan", "v7_pan", "v8_pan",
                               "v1_fx1", "v2_fx1", "v3_fx1", "v4_fx1", "v5_fx1", "v6_fx1", "v7_fx1", "v8_fx1",
                               "v1_fx2", "v2_fx2", "v3_fx2", "v4_fx2", "v5_fx2", "v6_fx2", "v7_fx2", "v8_fx2"]
                },
                "FX": {
